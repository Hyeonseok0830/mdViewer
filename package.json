{
  "name": "mdviewer",
  "version": "0.1.0",
  "description": "로컬 마크다운 파일 브라우저 실시간 뷰어",
  "author": {
    "name": "Hyeonseok",
    "email": "96hyeonseok@gmail.com",
    "url": "https://github.com/Hyeonseok0830"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hyeonseok0830/mdViewer.git"
  },
  "homepage": "https://github.com/Hyeonseok0830/mdViewer",
  "license": "MIT",
  "type": "module",
  "main": "./dist/src/electron/main.js",
  "bin": {
    "mdviewer": "./dist/bin/mdviewer.js"
  },
  "scripts": {
    "dev": "tsx bin/mdviewer.ts",
    "build": "tsc",
    "test": "vitest run",
    "electron:dev": "tsc && electron .",
    "electron:build": "tsc && electron-builder --win",
    "electron:build:nsis": "tsc && electron-builder --win --target=nsis",
    "electron:build:appx": "tsc && electron-builder --win --target=appx"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.0.0",
    "chokidar": "^3.6.0",
    "fastify": "^5.9.0",
    "gray-matter": "^4.0.3",
    "hast-util-to-string": "^3.0.1",
    "rehype-katex": "^7.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.0",
    "shiki": "^4.3.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "electron": "^41.7.1",
    "electron-builder": "^26.15.3",
    "png-to-ico": "^3.0.1",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.9"
  },
  "build": {
    "appId": "com.mdviewer.app",
    "productName": "mdViewer",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron{,/**}",
      "!node_modules/electron-builder{,/**}",
      "!node_modules/tsx{,/**}",
      "!node_modules/typescript{,/**}",
      "!node_modules/vitest{,/**}",
      "!node_modules/@vitest{,/**}",
      "!node_modules/esbuild{,/**}",
      "!node_modules/vite{,/**}"
    ],
    "asarUnpack": [
      "**/node_modules/katex/dist/**",
      "**/node_modules/shiki/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "appx",
          "arch": [
            "x64"
          ]
        }
      ],
      "fileAssociations": [
        {
          "ext": [
            "md",
            "markdown"
          ],
          "name": "Markdown File",
          "description": "Markdown 문서",
          "role": "Editor",
          "icon": "assets/icon.ico"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "mdViewer"
    },
    "appx": {
      "applicationId": "mdViewer",
      "displayName": "mdViewer",
      "identityName": "YourPublisherAlias.mdViewer",
      "publisher": "CN=YourName, O=YourOrg, C=KR",
      "publisherDisplayName": "YourName",
      "backgroundColor": "#0d1117",
      "languages": [
        "ko-KR",
        "en-US"
      ]
    }
  }
}
